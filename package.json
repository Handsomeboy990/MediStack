{
  "name": "meditrust",
  "version": "0.1.0",
  "private": true,
  "description": "MediTrust, cash desk and stock management platform for health centers",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
