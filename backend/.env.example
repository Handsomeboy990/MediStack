# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://meditrust:meditrust@localhost:5432/meditrust?schema=public"

# API listening port
PORT=3001

# Allowed frontend origin (CORS, fine grained configuration deferred)
FRONTEND_ORIGIN="http://localhost:3000"

# Runtime environment
NODE_ENV=development

# JWT authentication
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="1d"
