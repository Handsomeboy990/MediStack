# PostgreSQL connection used by Prisma at runtime.
# Neon: use the POOLED connection string (host contains "-pooler").
DATABASE_URL="postgresql://meditrust:meditrust@localhost:5432/meditrust?schema=public"

# Direct (non-pooled) connection used by Prisma migrations only.
# Neon: same URL WITHOUT "-pooler" in the host.
DIRECT_URL="postgresql://meditrust:meditrust@localhost:5432/meditrust?schema=public"

# API listening port
PORT=3001

# Allowed frontend origin (CORS, fine grained configuration deferred)
FRONTEND_ORIGIN="http://localhost:3000"

# Runtime environment
NODE_ENV=development
