// MediTrust Prisma schema.
// Target: PostgreSQL (Neon). Columns are mapped to snake_case via @map.
// Modeled from docs/db_schema.yml. All naming is in English.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ServiceCategory {
  consultation
  laboratory
  radiology
  pharmacy
  blood_bank
}

enum StockTransactionType {
  add
  remove
  transfer
  sold
}

enum CancellationStatus {
  pending
  approved
  rejected
}

enum PaymentMethod {
  cash
  mobile_money
  cheque
}

enum PaymentStatus {
  pending
  completed
  failed
}

// ---------------------------------------------------------------------------
// Access control: roles, permissions, users
// ---------------------------------------------------------------------------

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@id([roleId, permissionId])
  @@map("roles_permissions")
}

model User {
  id         String    @id @default(uuid())
  fullName   String    @map("full_name")
  profile    String?
  username   String    @unique
  password   String
  lastLogin  DateTime? @map("last_login")
  roleId     String    @map("role_id")
  role       Role      @relation(fields: [roleId], references: [id])
  personneId String?   @unique @map("personne_id")
  personne   Personne? @relation(fields: [personneId], references: [id])

  stockTransactions    StockTransaction[]
  invoicesAsCashier    Invoice[]                    @relation("Cashier")
  invoicesPrescribed   Invoice[]                    @relation("PrescribingDoctor")
  invoicesPerformed    Invoice[]                    @relation("PerformingDoctor")
  cancellationRequests InvoiceCancellationRequest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ---------------------------------------------------------------------------
// People and insurance
// ---------------------------------------------------------------------------

model Personne {
  id            String    @id @default(uuid())
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String?
  phoneNumbers  String[]  @map("phone_numbers")
  address       String?
  dateOfBirth   DateTime? @map("date_of_birth")
  gender        String?
  nationality   String?
  occupation    String?
  maritalStatus String?   @map("marital_status")

  user       User?
  insurances PersonneInsurance[]
  invoices   Invoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("personnes")
}

model InsuranceOrganisation {
  id            String   @id @default(uuid())
  name          String
  description   String?
  address       String?
  phoneNumbers  String[] @map("phone_numbers")
  email         String?
  website       String?
  contactPerson String?  @map("contact_person")

  memberships PersonneInsurance[]
  invoices    Invoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("insurance_organisations")
}

model PersonneInsurance {
  id                      String                @id @default(uuid())
  personneId              String                @map("personne_id")
  personne                Personne              @relation(fields: [personneId], references: [id], onDelete: Cascade)
  insuranceOrganisationId String                @map("insurance_organisation_id")
  insuranceOrganisation   InsuranceOrganisation @relation(fields: [insuranceOrganisationId], references: [id])
  discountPercentage      Decimal               @default(0) @map("discount_percentage") @db.Decimal(5, 2)
  startDate               DateTime?             @map("start_date")
  endDate                 DateTime?             @map("end_date")
  status                  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("personnes_insurances")
}

// ---------------------------------------------------------------------------
// Catalog: departments, specialities, services, pricing
// ---------------------------------------------------------------------------

model Departement {
  id          String    @id @default(uuid())
  name        String
  description String?
  services    Service[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("departements")
}

model Speciality {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("specialities")
}

model Service {
  id             String          @id @default(uuid())
  name           String
  description    String?
  departementId  String?         @map("departement_id")
  departement    Departement?    @relation(fields: [departementId], references: [id])
  category       ServiceCategory
  type           String?
  currentTarifId String?         @map("current_tarif_id")
  currentTarif   Tarification?   @relation("CurrentTarif", fields: [currentTarifId], references: [id])
  isCountable    Boolean         @default(false) @map("is_countable")
  stockAlerte    Int?            @map("stock_alerte")
  totalStock     Int?            @map("total_stock")
  currentStock   Int             @default(0) @map("current_stock")

  stockTransactions StockTransaction[]
  invoiceItems      InvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("services")
}

model Tarification {
  id              String    @id @default(uuid())
  serviceableId   String    @map("serviceable_id")
  serviceableType String    @map("serviceable_type")
  unitPriceIncl   Decimal   @map("unit_price_incl") @db.Decimal(12, 2)
  unitPriceExcl   Decimal   @map("unit_price_excl") @db.Decimal(12, 2)
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  version         Int       @default(1)

  invoiceItems       InvoiceItem[]
  currentForServices Service[]     @relation("CurrentTarif")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tarification")
}

// ---------------------------------------------------------------------------
// Stock
// ---------------------------------------------------------------------------

model StockTransaction {
  id              String               @id @default(uuid())
  serviceId       String               @map("service_id")
  service         Service              @relation(fields: [serviceId], references: [id])
  userId          String               @map("user_id")
  user            User                 @relation(fields: [userId], references: [id])
  quantity        Int
  transactionType StockTransactionType @map("transaction_type")
  date            DateTime             @default(now())

  createdAt DateTime @default(now()) @map("created_at")

  @@map("stock_transactions")
}

// ---------------------------------------------------------------------------
// Billing: invoices, items, cancellations, payments
// ---------------------------------------------------------------------------

model Invoice {
  id                   String                 @id @default(uuid())
  number               String                 @unique
  personneId           String                 @map("personne_id")
  personne             Personne               @relation(fields: [personneId], references: [id])
  insuranceId          String?                @map("insurance_id")
  insurance            InsuranceOrganisation? @relation(fields: [insuranceId], references: [id])
  cashierId            String                 @map("cashier_id")
  cashier              User                   @relation("Cashier", fields: [cashierId], references: [id])
  prescribingDoctorId  String?                @map("prescribing_doctor_id")
  prescribingDoctor    User?                  @relation("PrescribingDoctor", fields: [prescribingDoctorId], references: [id])
  performingDoctorId   String?                @map("performing_doctor_id")
  performingDoctor     User?                  @relation("PerformingDoctor", fields: [performingDoctorId], references: [id])
  date                 DateTime               @default(now())
  totalAmountExcl      Decimal                @default(0) @map("total_amount_excl") @db.Decimal(12, 2)
  totalAmountIncl      Decimal                @default(0) @map("total_amount_incl") @db.Decimal(12, 2)
  totalInsuranceAmount Decimal                @default(0) @map("total_insurance_amount") @db.Decimal(12, 2)
  totalPatientAmount   Decimal                @default(0) @map("total_patient_amount") @db.Decimal(12, 2)

  items                InvoiceItem[]
  cancellationRequests InvoiceCancellationRequest[]
  payments             Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invoices")
}

model InvoiceItem {
  id              String       @id @default(uuid())
  invoiceId       String       @map("invoice_id")
  invoice         Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId       String       @map("service_id")
  service         Service      @relation(fields: [serviceId], references: [id])
  tarifId         String       @map("tarif_id")
  tarif           Tarification @relation(fields: [tarifId], references: [id])
  date            DateTime     @default(now())
  quantity        Int          @default(1)
  totalAmountExcl Decimal      @map("total_amount_excl") @db.Decimal(12, 2)
  totalAmountIncl Decimal      @map("total_amount_incl") @db.Decimal(12, 2)

  @@map("invoice_items")
}

model InvoiceCancellationRequest {
  id        String             @id @default(uuid())
  invoiceId String             @map("invoice_id")
  invoice   Invoice            @relation(fields: [invoiceId], references: [id])
  userId    String             @map("user_id")
  user      User               @relation(fields: [userId], references: [id])
  reason    String
  status    CancellationStatus @default(pending)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invoice_cancellations_requests")
}

model Payment {
  id                String        @id @default(uuid())
  invoiceId         String        @map("invoice_id")
  invoice           Invoice       @relation(fields: [invoiceId], references: [id])
  externalReference String?       @map("external_reference")
  amount            Decimal       @db.Decimal(12, 2)
  paymentMethod     PaymentMethod @map("payment_method")
  date              DateTime      @default(now())
  amountReceived    Decimal       @default(0) @map("amount_received") @db.Decimal(12, 2)
  amountRemainder   Decimal       @default(0) @map("amount_remainder") @db.Decimal(12, 2)
  status            PaymentStatus @default(pending)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payments")
}
