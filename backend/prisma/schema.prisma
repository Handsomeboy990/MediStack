// MediTrust Prisma schema.
// Target: PostgreSQL. Columns are mapped to snake_case via @map.
// This schema covers the data model from the specifications document.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Application roles: Director, Cash manager, Cashier, Storekeeper, HR.
model Role {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  libelle     String
  description String?
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id           String   @id @default(uuid())
  nom          String
  prenom       String
  email        String   @unique
  telephone    String?
  motDePasse   String   @map("mot_de_passe")
  actif        Boolean  @default(true)
  roleId       Int      @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id])
  factures     Facture[]
  paiements    Paiement[]
  mouvements   MouvementStock[]
  demandes     DemandeAnnulation[] @relation("demandeur")
  traitements  DemandeAnnulation[] @relation("traiteur")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Assurance {
  id          String    @id @default(uuid())
  nom         String
  tauxCouverture Decimal @default(0) @map("taux_couverture") @db.Decimal(5, 2)
  actif       Boolean   @default(true)
  patients    Patient[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("assurances")
}

model Patient {
  id            String   @id @default(uuid())
  matricule     String   @unique
  nom           String
  prenom        String
  dateNaissance DateTime? @map("date_naissance")
  sexe          String?
  telephone     String?
  adresse       String?
  assuranceId   String?  @map("assurance_id")
  assurance     Assurance? @relation(fields: [assuranceId], references: [id])
  contacts      PatientContact[]
  factures      Facture[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("patients")
}

// Emergency contact person for a patient. A patient may register one or two
// contacts; this limit is enforced in the application layer.
model PatientContact {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nom         String
  prenom      String?
  telephone   String
  lien        String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("patient_contacts")
}

model Specialite {
  id        String    @id @default(uuid())
  code      String    @unique
  libelle   String
  medecins  Medecin[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("specialites")
}

model Medecin {
  id           String     @id @default(uuid())
  nom          String
  prenom       String
  telephone    String?
  specialiteId String?    @map("specialite_id")
  specialite   Specialite? @relation(fields: [specialiteId], references: [id])
  prestations  Prestation[]
  factures     Facture[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("medecins")
}

model Prestation {
  id          String   @id @default(uuid())
  code        String   @unique
  libelle     String
  prix        Decimal  @db.Decimal(12, 2)
  actif       Boolean  @default(true)
  medecinId   String?  @map("medecin_id")
  medecin     Medecin? @relation(fields: [medecinId], references: [id])
  lignes      FactureLigne[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("prestations")
}

model StockMagasinCentral {
  id            String   @id @default(uuid())
  code          String   @unique
  libelle       String
  unite         String?
  quantite      Int      @default(0)
  seuilAlerte   Int      @default(0) @map("seuil_alerte")
  prixUnitaire  Decimal  @default(0) @map("prix_unitaire") @db.Decimal(12, 2)
  mouvements    MouvementStock[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("stock_magasin_central")
}

// Movement type: ENTREE, SORTIE, AJUSTEMENT.
model MouvementStock {
  id          String   @id @default(uuid())
  articleId   String   @map("article_id")
  article     StockMagasinCentral @relation(fields: [articleId], references: [id])
  type        String
  quantite    Int
  motif       String?
  agentId     String?  @map("agent_id")
  agent       User?    @relation(fields: [agentId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("mouvements_stock")
}

// Invoice status: EN_ATTENTE, PAYEE, ANNULEE, PARTIELLE.
model Facture {
  id            String   @id @default(uuid())
  numero        String   @unique
  patientId     String   @map("patient_id")
  patient       Patient  @relation(fields: [patientId], references: [id])
  medecinId     String?  @map("medecin_id")
  medecin       Medecin? @relation(fields: [medecinId], references: [id])
  agentId       String   @map("agent_id")
  agent         User     @relation(fields: [agentId], references: [id])
  montantTotal  Decimal  @default(0) @map("montant_total") @db.Decimal(12, 2)
  montantPaye   Decimal  @default(0) @map("montant_paye") @db.Decimal(12, 2)
  statut        String   @default("EN_ATTENTE")
  lignes        FactureLigne[]
  paiements     Paiement[]
  demandes      DemandeAnnulation[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("factures")
}

model FactureLigne {
  id            String   @id @default(uuid())
  factureId     String   @map("facture_id")
  facture       Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)
  prestationId  String?  @map("prestation_id")
  prestation    Prestation? @relation(fields: [prestationId], references: [id])
  designation   String
  quantite      Int      @default(1)
  prixUnitaire  Decimal  @map("prix_unitaire") @db.Decimal(12, 2)
  montantLigne  Decimal  @map("montant_ligne") @db.Decimal(12, 2)

  @@map("facture_lignes")
}

// Payment mode: ESPECES, MOBILE_MONEY, CARTE, ASSURANCE.
model Paiement {
  id          String   @id @default(uuid())
  factureId   String   @map("facture_id")
  facture     Facture  @relation(fields: [factureId], references: [id])
  montant     Decimal  @db.Decimal(12, 2)
  mode        String
  reference   String?
  agentId     String   @map("agent_id")
  agent       User     @relation(fields: [agentId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("paiements")
}

// Request status: EN_ATTENTE, APPROUVEE, REFUSEE.
model DemandeAnnulation {
  id            String   @id @default(uuid())
  factureId     String   @map("facture_id")
  facture       Facture  @relation(fields: [factureId], references: [id])
  motif         String
  statut        String   @default("EN_ATTENTE")
  demandeurId   String   @map("demandeur_id")
  demandeur     User     @relation("demandeur", fields: [demandeurId], references: [id])
  traiteurId    String?  @map("traiteur_id")
  traiteur      User?    @relation("traiteur", fields: [traiteurId], references: [id])
  traiteLe      DateTime? @map("traite_le")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("demandes_annulation")
}
