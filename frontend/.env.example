# Base URL of the MediTrust API, consumed by the centralized HTTP client
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# Whisper transcription endpoint (expects multipart/form-data with field: file)
WHISPER_API_URL="http://localhost:8000/transcribe"

# DeepSeek API configuration (server side only)
DEEPSEEK_API_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-flash"
DEEPSEEK_API_KEY=""
